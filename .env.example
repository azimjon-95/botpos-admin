# BOT·POS Admin Panel — .env namunasi
# Nusxa: copy .env.example .env

# Backend API manzili
# NGINX orqali (tavsiya):
REACT_APP_API_BASE_URL=http://localhost:8080
# To'g'ridan (NGINX yo'q bo'lsa):
# REACT_APP_API_BASE_URL=http://localhost:6060

# Login emailini formada ko'rsatish (ixtiyoriy)
REACT_APP_ADMIN_EMAIL=admin@botpos.uz
